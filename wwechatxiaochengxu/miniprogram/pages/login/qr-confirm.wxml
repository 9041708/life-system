<view class="page">
  <view class="tip-text">请对准PC端二维码进行扫描，或手动输入token。</view>

  <view class="card">
    <view class="title">扫码确认</view>
    <button class="btn-primary" bindtap="onScan">打开扫码</button>
  </view>

  <view class="card">
    <view class="title">手动输入</view>
    <input class="input" placeholder="输入PC显示的token" value="{{tokenInput}}" bindinput="onTokenInput" />
    <button class="btn-secondary" loading="{{submitting}}" bindtap="onConfirmManual">确认登录</button>
  </view>
</view>