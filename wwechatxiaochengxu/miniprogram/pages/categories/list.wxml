<!-- miniprogram/pages/categories/list.wxml -->
<view class="page theme-{{theme}}">
  <!-- 顶部类型切换 -->
  <view class="tabs">
    <view
      wx:for="{{typeTabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      class="tab-item {{currentType === item.key ? 'active' : ''}}"
      bindtap="onTabChange"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 提示文案 -->
  <view class="tip-text">
    在这里可以直接管理支出/收入分类，方便只用手机时完成初始化配置。
  </view>

  <!-- 分类列表 -->
  <view class="list">
    <view
      class="cat-item"
      wx:for="{{categories}}"
      wx:key="id"
    >
      <image
        wx:if="{{item.icon_url}}"
        class="cat-icon"
        src="{{item.icon_url}}"
        mode="aspectFit"
      />
      <view class="cat-main">
        <view class="cat-name">{{item.name}}</view>
        <view class="cat-sub">排序：{{item.sort_order}}</view>
      </view>
      <view class="cat-actions">
        <text
          class="action-link"
          data-id="{{item.id}}"
          bindtap="onEditTap"
        >编辑</text>
        <text
          class="action-link danger"
          data-id="{{item.id}}"
          bindtap="onDeleteTap"
        >删除</text>
      </view>
    </view>

    <view class="empty" wx:if="{{!loading && categories.length === 0}}">
      暂无分类
    </view>
    <view class="loading" wx:if="{{loading}}">
      加载中…
    </view>
  </view>

  <!-- 底部操作：新增分类按钮 -->
  <view class="footer-actions">
    <button class="btn-primary" bindtap="onAddNew">新增分类</button>
  </view>

  <!-- 管理子菜单：账户列表 / 分类管理 / 项目管理 -->
  <view class="manage-subtab">
    <view class="manage-subtab-item" bindtap="onNavAccounts">账户列表</view>
    <view class="manage-subtab-item manage-active" bindtap="onNavCategories">分类管理</view>
    <view class="manage-subtab-item" bindtap="onNavItems">项目管理</view>
  </view>

  <!-- 新增 / 编辑 弹窗表单 -->
  <view wx:if="{{showFormModal}}" class="modal-mask">
    <view class="modal-container">
      <view class="modal-title">
        {{editingId ? '编辑分类' : '新增分类'}}
      </view>
      <view class="modal-body">
        <view class="form-item">
          <input
            class="input"
            placeholder="分类名称，如：餐饮、交通"
            value="{{nameInput}}"
            bindinput="onNameInput"
          />
        </view>
        <view class="form-item">
          <input
            class="input"
            placeholder="排序（可选，数字越小越靠前）"
            value="{{sortInput}}"
            bindinput="onSortInput"
          />
        </view>

        <!-- 图标上传与图标库选择 -->
        <view class="icon-section">
          <view class="icon-title">图标设置（可选）</view>
          <view class="icon-upload-row">
            <input
              class="input icon-name-input"
              placeholder="图标名称（用于图标库显示，可选）"
              value="{{newIconName}}"
              bindinput="(e)=>{this.setData({newIconName: e.detail.value})}"
            />
            <button
              class="btn-upload"
              loading="{{uploadingIcon}}"
              bindtap="onUploadIcon"
            >上传图标</button>
          </view>

          <view class="icon-grid" wx:if="{{iconLibrary.length > 0}}">
            <view
              class="icon-item {{item.id === selectedIconId ? 'active' : ''}}"
              wx:for="{{iconLibrary}}"
              wx:key="id"
              data-id="{{item.id}}"
              bindtap="onIconSelect"
            >
              <image class="icon-img" src="{{item.file_url}}" mode="aspectFit" />
            </view>
          </view>
          <view class="icon-actions">
            <text class="action-link" bindtap="onClearIcon">清除图标</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="onCloseModal">取消</button>
        <button
          class="btn-primary"
          loading="{{submitting}}"
          bindtap="onSubmit"
        >
          {{editingId ? '保存修改' : '新增分类'}}
        </button>
      </view>
    </view>
  </view>
</view>
