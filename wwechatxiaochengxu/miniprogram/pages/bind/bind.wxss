.container {
  padding: 60rpx 40rpx;
}

.title {
  font-size: 32rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 24rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.btn {
  margin-top: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 8rpx;
}